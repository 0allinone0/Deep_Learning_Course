#Logistic Regression 구현
import numpy as np

def sigmoid(x):             #0과 1사이의 값으로 바꿔줌
    return 1 / (1 + np.exp(-x))

def compute_cost(theta, x, y): #theta가 weight
    m = len(y)      #데이터의 개수
    y_pred = sigmoid(np.dot(x, theta))  #x (dot product) w(theta)
    error = (y * np.log(y_pred) + (1 - y) * np.log(1 - y_pred))   #각 데이터 마다의 에러값 구하는것
    cost = -1 / m * sum(error)    #평균 에러값 -가 붙은 이유는 log값이 음수이기 때문
    gradient = 1 / m * np.dot(x.transpose(), (y_pred - y)) ##cost는 theta로 미분한 값, 
                                                            #예측이 실제보다 크면 줄이는 방향
                                                            #예측이 실제보다 작으면 늘리는 방향
    return cost[0], gradient        

#Feature 분리
x1 = inputs[:, 0].reshape(-1, 1) 
x2 = inputs[:, 1].reshape(-1, 1)

#normalization for stable  (z-score normalization)
mean_inputs = np.mean(inputs, axis=0)  #axis =0는 세로 방향으로 mean값을 구하라는 의미 -> 각 feature의 평균
std_inputs = np.std(inputs, axis=0)   # 각 feature 마다 표준편차 구하라
inputs = (inputs - mean_inputs) / std_inputs # z-score normalization

rows = inputs.shape[0] #샘플 수 저장
cols = inputs.shape[1]  #feature 개수 저장


X = np.append(np.ones((rows, 1)), inputs, axis=1)  #가로 형태로 1값을 열마다 하나씩 추가
y = target.reshape(rows, 1)   #target 열벡터로 변환


theta_init = np.zeros((cols + 1, 1))   # theta -> [w1, w2, w3]
cost, gradient = compute_cost(theta_init, X, y)

print("Cost at initialization", cost)
print("Gradient at initialization:", gradient)

#Gradient Descent 구현
def gradient_descent(x, y, theta, alpha, iterations):    #alpha: 학습률(learning rate)
    costs = []
    for i in range(iterations):
        cost, gradient = compute_cost(theta, x, y)
        theta -= (alpha * gradient)
        costs.append(cost)
    return theta, costs

#학습 실행
theta, costs = gradient_descent(X, y, theta_init, 1 ,5000)   #학습된 theta와 매 반복의 costs 값들

#예측 함수
def predict(theta, x):
    results = x.dot(theta)
    return results > 0

#결과 출력
